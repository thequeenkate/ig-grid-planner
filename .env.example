# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local or share these values with anyone (or any chat).

# Required: your Notion internal integration token (create at notion.so/my-integrations)
NOTION_TOKEN=

# Required: the ID of your content calendar database
NOTION_SOCIAL_CALENDAR_DB=

# Optional: set this when deploying online (e.g. Vercel) to password-protect the planner.
# Leave empty when running locally.
APP_PASSWORD=

# Optional: "Live on Instagram" strip. Skip on first setup.
INSTAGRAM_ACCESS_TOKEN=
# Date the Instagram token was created (YYYY-MM-DD), used for the 60-day expiry countdown
INSTAGRAM_TOKEN_DATE=
